# Copy this file to .streamlit/secrets.toml and fill in real values.
# .streamlit/secrets.toml is gitignored — never commit it.
#
# On Railway, set the same values as service env-backed secrets
# (Streamlit reads them from secrets.toml on disk at startup).
#
# Required Google OAuth setup:
# 1. Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web application)
# 2. Register authorized redirect URIs:
#      https://<railway-domain>/oauth2callback
#      http://localhost:8501/oauth2callback   (for local dev)
# 3. Paste the client_id / client_secret below.

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "replace-with-long-random-string"

[auth.google]
client_id = "your-client-id.apps.googleusercontent.com"
client_secret = "your-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
